{
  "manifest_version": 2,
  "name": "OpenClaw Browser MCP",
  "version": "1.0.5",
  "description": "MCP server for Firefox browser automation via WebSocket",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "openclaw-firefox-mcp@openclaw.ai",
      "strict_min_version": "91.0"
    }
  },
  
  "permissions": [
    "tabs",
    "activeTab",
    "contextMenus",
    "downloads",
    "history",
    "bookmarks",
    "storage",
    "<all_urls>"
  ],
  
  "background": {
    "scripts": ["background-ws.js"],
    "persistent": true
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
