#!/bin/bash
# Firefox MCP CLI - 简化版

TOOL=$1
ARGS=${2:-{}}

if [ -z "$TOOL" ]; then
    echo "Usage: firefox-mcp <tool> [args]"
    echo ""
    echo "Available tools:"
    echo "  firefox_navigate '{\"url\": \"https://...\"}'"
    echo "  firefox_get_tabs"
    echo "  firefox_get_current_url"
    echo "  firefox_get_page_title"
    echo "  firefox_get_page_content"
    echo "  firefox_click '{\"selector\": \"...\"}'"
    echo "  firefox_type '{\"selector\": \"...\", \"text\": \"...\"}'"
    echo "  firefox_screenshot"
    echo "  firefox_execute_js '{\"code\": \"...\"}'"
    echo "  firefox_wait '{\"duration\": 2}'"
    exit 1
fi

# 检查服务器是否运行
if ! curl -s http://localhost:34567/health > /dev/null 2>&1; then
    echo "Error: Firefox MCP server is not running"
    echo "Starting server..."
    ~/.openclaw/firefox-mcp/bin/start-server &
    sleep 2
fi

# 执行工具调用
cd /var/home/houge/.openclaw/firefox-mcp/mcp-server
node /tmp/firefox-mcp-cli.js "$TOOL" "$ARGS" 2>/dev/null
